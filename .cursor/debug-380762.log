47\u043d\u043e\u0441\u0442\u0438 \u043f\u0440\u043e\u0438\u0437\u0432\u0435\u0434\u0435\u043d\u043e \u043e\u043a\u0440\u0443\u0433\u043b\u0435\u043d\u0438\u0435 \u0441\u043e\u0433\u043b\u0430\u0441\u043d\u043e MS Excel, \u0432\u0441\u043b\u0435\u0434\u0441\u0442\u0432\u0438\u0435 \n\u0447\u0435\u0433\u043e \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442 \u043f\u0440\u044f\u043c\u043e\u0433\u043e \u0432\u044b\u0447\u0438\u0441\u043b\u0435\u043d\u0438\u044f \u043c\u043e\u0436\u0435\u0442 \u043e\u0442\u043b\u0438\u0447\u0430\u0442\u044c\u0441\u044f \u043e\u0442 \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u043d\u043e\u0433\u043e \u0441 \u0442\u043e\u0447\u043d\u043e\u0441\u0442\u044c\u044e \u043f\u043e\u0433\u0440\u0435\u0448\u043d\u043e\u0441\u0442\u0438 \n\u043e\u043a\u0440\u0443\u0433\u043b\u0435\u043d\u0438\u044f, \u0447\u0442\u043e \u043d\u0435 \u044f\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u043e\u0448\u0438\u0431\u043a\u043e\u0439.\n\u0412\u0441\u0435 \u0440\u0430\u0441\u0447\u0435\u0442\u044b \u043f\u0440\u0438\u0432\u0435\u0434\u0435\u043d\u044b \u0432 \u0444\u0430\u0439\u043b\u0435 MSN5031_TH-003999231_Fatigue_calc_v1.94.xlsm.\n\u0412 \u0434\u0430\u043d\u043d\u043e\u043c \u0440\u0430\u0437\u0434\u0435\u043b\u0435 \u043f\u0440\u0438\u0432\u0435\u0434\u0435\u043d \u0430\u043d\u0430\u043b\u0438\u0437 \u0432\u043b\u0438\u044f\u043d\u0438\u044f \u043d\u0430 \u0443\u0441\u0442\u0430\u043b\u043e\u0441\u0442\u043d\u0443\u044e \u043f\u0440\u043e\u0447\u043d\u043e\u0441\u0442\u044c \u0434\u0435\u0442\u0430\u043b\u0435\u0439 \u0432 \u0437\u043e\u043d\u0435 \u0440\u0435\u043c\u043e\u043d\u0442\u0430 \nTH-003999231, \n\u0432\u044b\u043f\u043e\u043b\u043d\u0435\u043d\u043d\u043e\u0433\u043e \n\u043d\u0430 \n\u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0441\u0442\u0432\u0435. \n\u041f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0438\u0442\u0435\u043b\u044c \n\u0412\u0421 \n\u043f\u0440\u0438\u0441\u0432\u043e\u0438\u043b \n\u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0438\u0435 \n\u0445\u0430\u0440\u0430\u043a\u0442\u0435\u0440\u0438\u0441\u0442\u0438\u043a\u0438 \u0434\u043b\u044f \u043a\u043b\u0430\u0441\u0441\u0438\u0444\u0438\u043a\u0430\u0446\u0438\u0438 \u043f\u0440\u043e\u0438\u0437\u0432\u0435\u0434\u0435\u043d\u043d\u044b\u0445 \u0440\u0430\u0431\u043e\u0442:\n\u2212 \n\u0441\u0443\u0444\u0444\u0438\u043a\u0441 \u0432 \u043e\u043f\u0438\u0441\u0430\u043d\u0438\u0438 \u043e\u0442\u043a\u043b\u043e\u043d\u0435\u043d\u0438\u044f: \u00ab\u0421\u00bb.\n5.1 \u041e\u041f\u0418\u0421\u0410\u041d\u0418\u0415 \u0420\u0415\u041c\u041e\u041d\u0422\u0410\n\u041d\u0430 \u043f\u0440\u0430\u0432\u043e\u043c \u0431\u043e\u0440\u0442\u0443 \u0444\u044e\u0437\u0435\u043b\u044f\u0436\u0430 \u0432 \u0437\u043e\u043d\u0435 \u0441\u043e\u0435\u0434\u0438\u043d\u0435\u043d\u0438\u044f \u0448\u043f\u0430\u043d\u0433\u043e\u0443\u0442\u0430 42 \u0438 \u0431\u043e\u043a\u043e\u0432\u043e\u0439 \u043f\u0430\u043d\u0435\u043b\u0438 \u043e\u0431\u0448\u0438\u0432\u043a\u0438 \u043c\u0435\u0436\u0434\u0443 \n\u0441\u0442\u0440\u0438\u043d\u0433\u0435\u0440\u0430\u043c\u0438 14 \u0438 18 \u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043b\u0435\u043d\u043e \u0434\u0432\u0430 \u043a\u0440\u0435\u043f\u0435\u0436\u0430 \u0431\u043e\u043b\u044c\u0448\u0435\u0433\u043e \u0434\u0438\u0430\u043c\u0435\u0442\u0440\u0430. \u0414\u0430\u043d\u043d\u043e\u0435 \u043d\u0435\u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0435 \u043e\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u043e \n\u0431\u0435\u0437 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0439. \u0414\u0430\u043d\u043d\u044b\u0435 \u043e\u0431 \u0442\u0440\u0432\u043a\u0442\u043e\u0440\u0438\u0441\u0442\u0430\u0445 \u043f\u0440\u0438\u0432\u0435\u0434\u0435\u043d\u044b \u0432 \u0442\u0430\u0431\u043b\u0438\u0446\u0435 5.1-1. \u041e\u043f\u0438\u0441\u0430\u043d\u0438\u0435 \u043e\u0431\u043b\u0430\u0441\u0442\u0438 \u0438 \u0442\u0438\u043f\u0430 \n\u0430\u0