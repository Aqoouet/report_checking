# LM Studio API (running in Docker on the host, port 1234)
OPENAI_API_KEY=lm-studio
OPENAI_BASE_URL=http://host.docker.internal:1234/v1

# Model name — must match what's loaded in LM Studio
# Check: docker exec lmstudio lms ps
# Must match a loaded model id from LM Studio (see: curl http://localhost:1234/v1/models)
# Example: local qwen coder snapshot
OPENAI_MODEL=qwen3-coder-30b-a3b-instruct

# System prompt for report review
SYSTEM_PROMPT=Ты эксперт по проверке отчётов. Проверь следующий фрагмент отчёта и дай подробный комментарий по каждому из пунктов:\n1. Соответствие содержания теме\n2. Логика и структура изложения\n3. Точность формулировок\n4. Наличие необходимых выводов\n5. Оформление (если применимо)\nОтвет давай чётко по пунктам.

# Seconds to wait for the model to respond per page.
# Coder models can be slower — allow up to 10 min per page.
AI_TIMEOUT=600

# Port the web UI will be available on
APP_PORT=5173
