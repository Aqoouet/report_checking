# LM Studio API (running in Docker on the host, port 1234)
OPENAI_API_KEY=lm-studio
OPENAI_BASE_URL=http://host.docker.internal:1234/v1

# Model name — must match what's loaded in LM Studio
# Check: docker exec lmstudio lms ps
# Must match a loaded model id from LM Studio (see: curl http://localhost:1234/v1/models)
# Example: local qwen coder snapshot
OPENAI_MODEL=qwen3-coder-30b-a3b-instruct

# Model id for /validate_range only — must match the exact "id" from LM Studio (curl http://localhost:1234/v1/models).
# Default in docker-compose: qwen/qwen3-4b-2507. Set to OPENAI_MODEL if you want the same model as main checks.
OPENAI_VALIDATE_MODEL=qwen/qwen3-4b-2507

# Seconds to wait for the model to finish a response (read timeout).
# 0 or empty = unlimited (good for slow local models / long runs). Set e.g. 600 for a hard cap.
AI_TIMEOUT=0

# Fail fast if LM Studio is unreachable (TCP / TLS handshake), seconds. Ignored when AI_TIMEOUT is unlimited (whole client has no timeout).
AI_CONNECT_TIMEOUT=15

# Approximate characters per fragment sent to the LLM (clarity/units checkpoints).
DOC_CHUNK_SIZE=10000

# Max completion tokens for chunk checks (clarity/units/references): 0 or empty = omit max_tokens (server default).
AI_CHUNK_MAX_TOKENS=0

# Port the web UI will be available on
APP_PORT=5173

# Host roots mounted into backend container for Windows path mapping:
# U:\ -> /filer/users/rymax1e, P:\ -> /filer/wps/wp
# Override on each server if host directories differ.
# HOST_STORAGE_U=/filer/users/rymax1e
# HOST_STORAGE_P=/filer/wps/wp

# Backend container runtime user.
# Use 0:0 by default to read restrictive network shares.
# If your filer ACLs allow it, set non-root uid/gid explicitly.
# BACKEND_UID=0
# BACKEND_GID=0

# --- Docling document parser (optional) ---
# Set USE_DOCLING=true to route .docx files through the docling-serve container
# instead of the built-in python-docx / OOXML parser.  The service uses IBM Docling
# for ML-based document structure understanding.
#
# Uses the official image: ghcr.io/docling-project/docling-serve-cpu (~4.4 GB).
# Pull it once with: docker pull ghcr.io/docling-project/docling-serve-cpu:latest
#
# USE_DOCLING=false
# DOCLING_URL=http://docling:5001
# DOCLING_TIMEOUT=180

# --- Docker build base images (optional) ---
# If `docker compose build` fails with TLS handshake timeout to registry-1.docker.io, either:
# - pull bases when the network is stable: docker pull node:20-alpine python:3.12-slim nginx:alpine
# - configure a registry mirror in /etc/docker/daemon.json (see Docker docs), or
# - set mirrors below (your org / public mirror URLs that host the same images).
# DOCKER_NODE_IMAGE=node:20-alpine
# DOCKER_PYTHON_IMAGE=python:3.12-slim
# DOCKER_NGINX_IMAGE=nginx:alpine
