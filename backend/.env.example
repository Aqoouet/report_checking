# Local backend development only (direct Python/uvicorn, no Docker).
# For Docker/deployment defaults, see ../.env.example. That root file is the
# canonical environment reference.
#
# Minimum required for local dev:
OPENAI_API_KEY=lm-studio
OPENAI_BASE_URL=http://localhost:1234/v1

# Must match the exact model id loaded in LM Studio (curl http://localhost:1234/v1/models).
OPENAI_MODEL=your-model-id

# Optional: separate lighter model for /validate_range. Defaults to OPENAI_MODEL if unset.
# OPENAI_VALIDATE_MODEL=your-lite-model-id

# Optional: comma-separated worker server list as JSON array.
# Jobs will queue until servers are configured via this env var.
# Example: WORKER_SERVERS=[{"url":"http://localhost:5000","concurrency":3}]
WORKER_SERVERS=
