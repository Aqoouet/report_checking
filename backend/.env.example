# LM Studio (локальный сервер) — API-ключ может быть любой строкой
OPENAI_API_KEY=lm-studio
OPENAI_BASE_URL=http://localhost:1234/v1

# Имя модели должно совпадать с тем, что загружено в LM Studio
# (можно посмотреть в разделе "Local Server" → выбранная модель)
OPENAI_MODEL=qwen3.5-2b

# Только для /validate_range — точный id из LM Studio. Пусто = OPENAI_MODEL.
OPENAI_VALIDATE_MODEL=qwen/qwen3-4b-2507

